# ─────────────────────────────────────────
#  KABOHA COFFEE — .gitignore
# ─────────────────────────────────────────

# ── Entorno virtual ──────────────────────
venv/
env/
.venv/
ENV/

# ── Variables de entorno (NUNCA subir) ───
.env
.env.*
*.env

# ── Base de datos local ──────────────────
db.sqlite3
*.sqlite3

# ── Archivos de documentación interna ────
# (fixes, bugs, comandos, guías de desarrollo)
CAMBIOS_DETALLADOS.md
COMANDOS_UTILES.sh
FIXES_SUMMARY.md
README_FIXES.md
RESUMEN_BUGS_CORREGIDOS.md
SOLUCION_BUGS.md
SOLUCION_STRIPE_LOADING.md
START_HERE.md
STRIPE_PAYMENT_ELEMENT.md
VERIFICATION_REPORT.md
guia.txt
start_dev.sh
verify_deployment.sh

# ── Logs ─────────────────────────────────
logs/*.log
logs/*.log.*
*.log
*.log.*
!logs/.gitkeep

# ── Archivos estáticos compilados ────────
staticfiles/

# ── Archivos de media subidos ────────────
media/

# ── Python ───────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Django ───────────────────────────────
*.pot
local_settings.py

# ── Pytest / Coverage ────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDEs y editores ──────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Node (por si acaso) ──────────────────
node_modules/
npm-debug.log*